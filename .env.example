# ============================================================
# Pravokha — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Backend API URL (no trailing slash)
VITE_API_URL=https://your-backend.com/api

# Google OAuth Client ID (for SSO login — FIX #5)
# Get from: https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Set Authorized origins: https://yourdomain.com
# Set Authorized redirect URIs: https://yourdomain.com/auth
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com

# Google Analytics (optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# App Info
VITE_APP_NAME=Pravokha
VITE_APP_URL=https://yourdomain.com
